# --- LLM credentials ---
# Default provider (Anthropic / Claude Sonnet 5):
ANTHROPIC_API_KEY=

# Only needed if you switch config.yaml to provider: openai_compatible
LLM_API_KEY=

# --- Later phases ---
WAKE_WORD=hey jarvis

# Shared secret so the web app can reach this Mac's brain.
# Set to a long random string (e.g. `openssl rand -hex 24`) and put the
# SAME value in the Vercel project's env vars.
JARVIS_TOKEN=
