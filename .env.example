# Password required to open the dashboard (set the same in Vercel env vars)
DASHBOARD_PASSWORD=

# The Mac brain: the website is a remote face onto Jarvis running on your Mac.
# MAC_BRAIN_URL — the Cloudflare tunnel URL to your Mac (e.g. https://jarvis.example.com)
# JARVIS_TOKEN  — the SAME long random string set in the Mac's Jarvis .env
MAC_BRAIN_URL=
JARVIS_TOKEN=
